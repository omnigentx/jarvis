# FastAgent Secrets Configuration
# Keys defined here will override the values in fastagent.config.yaml via deep merge.

mcp:
  servers:
    github:
      env:
        GITHUB_PERSONAL_ACCESS_TOKEN: ""
    brave-search:
      env:
        BRAVE_API_KEY: ""
    serpapi:
      url: "https://mcp.serpapi.com/{key}/mcp"
    linear:
      env:
        LINEAR_API_KEY: ""

anthropic:
  api_key: ""

openai:
  api_key: ""
  base_url: "https://api.openai.com/v1"

google:
  api_key: ""
