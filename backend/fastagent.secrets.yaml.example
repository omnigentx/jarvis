# FastAgent Secrets Configuration
# Keys defined here will override the values in fastagent.config.yaml via deep merge.

mcp:
  servers:
    github:
      env:
        GITHUB_PERSONAL_ACCESS_TOKEN: ""
    brave-search:
      env:
        BRAVE_API_KEY: ""
    serpapi:
      url: "https://mcp.serpapi.com/{key}/mcp"
    linear:
      env:
        LINEAR_API_KEY: ""
    # Override if Figma desktop runs on a different machine than Jarvis Docker
    # (e.g. Jarvis on a server, Figma on your laptop). Use Tailscale tailnet IP
    # or LAN IP reachable from the Docker container.
    # figma-ui-mcp:
    #   env:
    #     FIGMA_BRIDGE_HOST: "100.x.y.z"

anthropic:
  api_key: ""

openai:
  api_key: ""
  base_url: "https://api.openai.com/v1"

google:
  api_key: ""

# Messaging gateways (Telegram / Zalo) are configured in the UI, not here —
# Settings → Messaging Gateways. Tokens are stored encrypted in the DB and
# applied live (no restart). See backend/services/gateways/README.md.
