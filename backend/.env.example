# TTS Configuration (Edge TTS — free, no API key)
TTS_PROVIDER=edge
# Optional voice/rate overrides — see edge-tts docs for available voice ids.
# EDGE_TTS_VOICE=vi-VN-NamMinhNeural
# EDGE_TTS_RATE=+20%

# Roborock Configuration (For IoT features)
ROBOROCK_USERNAME=
ROBOROCK_PASSWORD=

# JWT Authentication
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# CORS Origins (comma-separated, * for all)
CORS_ORIGINS=*
