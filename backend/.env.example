# ── Required for backend to boot ─────────────────────────────────────────
#
# JARVIS_API_KEY: web/auth password (Bearer token + ?key= query param).
# Rotate freely — does NOT affect stored secrets.
# Auto-generated on first deploy by .github/workflows/deploy.yml.
# For a manual / OSS clone, generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
#
# ⚠ SECURITY: leaving this empty puts the backend in UNAUTHENTICATED mode
# (see backend/core/auth.py). That is only acceptable for first-boot Setup
# Wizard on localhost; never for any host reachable beyond 127.0.0.1.
JARVIS_API_KEY=__GENERATE_JARVIS_API_KEY__
#
# JARVIS_MASTER_KEY: Fernet master key for encrypting secrets at rest in
# the system_config table. NEVER rotate by just changing this value —
# every existing secret would become un-decryptable. Use
# `python -m scripts.rotate_master_key` (with JARVIS_MASTER_KEY_OLD/_NEW
# in env) to re-encrypt the DB, then update this var and restart.
#
# Generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
#
# UPGRADING from a build that used JARVIS_API_KEY as the master key:
# set this to the SAME value as your current JARVIS_API_KEY once, so
# existing ciphertext stays decryptable. Then you can rotate
# JARVIS_API_KEY independently.
JARVIS_MASTER_KEY=__GENERATE_JARVIS_MASTER_KEY__

# Voice config (TTS engines, STT, wake-word) lives in the DB and is managed
# via Settings → Voice in the dashboard. Edge TTS is the bootstrap default —
# no env var needed.

# Roborock Configuration (For IoT features)
ROBOROCK_USERNAME=
ROBOROCK_PASSWORD=

# JWT Authentication
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Rotating this value invalidates all existing dashboard sessions.
JWT_SECRET=__GENERATE_JWT_SECRET__
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# CORS Origins (comma-separated, * for all).
# ⚠ SECURITY: `*` is a permissive default suitable only for local dev.
# In production, list your dashboard origin(s) explicitly, e.g.
#   CORS_ORIGINS=https://jarvis.example.com,https://dashboard.example.com
CORS_ORIGINS=*

# Repository URL for agent git operations (experimental self-improvement flow).
# Auto-detected via `git remote get-url origin` if unset.
# Set explicitly only for multi-remote checkouts or when running outside a git tree.
# Per-user fork URL (e.g. https://github.com/<your-username>/jarvis) is normally
# stored in the encrypted DB via Settings → Services → jarvis_repo, NOT here.
# JARVIS_REPO_URL=
