# ─── Python ──────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
dist/
build/

# ─── Local research / scratch ────────────────────
.research/

# ─── System / IDE ────────────────────────────────
.DS_Store
.idea/
.vscode/
.claude

# ─── Secrets & Credentials ───────────────────────
*.env
backend/.env
backend/fastagent.secrets.yaml
backend/fastagent.secrets.docker.yaml
backend/git-credentials
backend/gitconfig
backend/git-credentials.tmp
backend/gitconfig.tmp
backend/credentials.json
backend/token.json
backend/token_calendar.json
backend/token_gmail.json
backend/firebase-credentials.json
backend/config/credentials/
backend/.keys/
# MCP server configs may inline live API tokens (Jira/Confluence/etc).
.mcp.json
# gh CLI host config (contains oauth_token).
backend/.gh-config/
# Runtime LLM tool-call dumps written by debugging research agents.
backend/.tool-outputs/

# ─── Backend Runtime / Data ──────────────────────
backend/.runtime/
backend/.fast-agent/sessions/
# MCP workspace: Jarvis-generated MCP servers + their isolated venvs + test runs.
# These are user-specific runtime artifacts (custom MCPs the agent wrote for itself),
# not source code to maintain.
backend/.fast-agent/mcp_workspace/
backend/fastagent.jsonl
backend/roborock_session.json
backend/temp_audio/
backend/data/

# ─── Logs ────────────────────────────────────────
*.log
build_log*.txt

# ─── Database ────────────────────────────────────
*.db
*.sqlite
*.sqlite3
backend/data/*.bak.*

# ─── Large / Binary Files ───────────────────────
*.dmg
*.zip
*.iso
*.tar.gz
*.apk
*.aab

# Codex (sensitive credentials)
backend/.codex/
backend/meetings/

# antigravity

.agents/
backend/core/logs/
.gitnexus

# ─── Onboarding snapshots (contain secrets) ──────
.onboard-backups/

# ─── Playwright E2E (dashboard) ──────────────────
dashboard/playwright-report/
dashboard/test-results/
backend/test-results/

# ─── Skill / agent-card auto-backups (.bak siblings created on edit) ──
backend/.fast-agent/skills/**/*.bak
backend/.fast-agent/agent_cards/**/*.bak
