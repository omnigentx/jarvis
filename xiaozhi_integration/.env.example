# Xiaozhi MCP endpoint — get this from your Xiaozhi mobile app
# Each endpoint is unique to one device and contains a JWT token; treat it as a secret.
MCP_ENDPOINT=wss://api.xiaozhi.me/mcp/?token=YOUR_TOKEN_HERE

# Jarvis backend configuration
# JARVIS_API_URL: where the Jarvis backend is reachable from this machine.
#   - same host: http://localhost:8000
#   - Docker:    http://host.docker.internal:8000
#   - LAN/VPN:   http://<server-ip>:8000
JARVIS_API_URL=http://localhost:8000

# JARVIS_API_KEY: MUST match the JARVIS_API_KEY value in your backend/.env.
# This is the Jarvis web/auth master Bearer token — never use the placeholder
# below in production. Generate a fresh value when you set up the backend.
JARVIS_API_KEY=__SAME_AS_BACKEND_JARVIS_API_KEY__
